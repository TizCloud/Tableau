      <column caption='Profit Level' datatype='string' name='[Calculation_1266976779747328]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &gt;= 150000 &#13;&#10;THEN &quot;High Profit&quot;&#13;&#10;ELSEIF SUM([Profit]) &gt;= 50000 AND SUM([Profit]) &lt; 150000&#13;&#10;THEN &quot;Medium Profit&quot;&#13;&#10;ELSEIF SUM([Profit]) &gt;= 0 AND SUM([Profit]) &lt; 50000&#13;&#10;THEN &quot;Low Profit&quot;&#13;&#10;ELSE &quot;Not Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1614972183285760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales]-[Profit]' />
      </column>
